{
  "name": "@notmanu/annotate",
  "version": "0.5.13",
  "module": "index.ts",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "annotate": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target node --format esm --packages external",
    "release": "bash scripts/publish.sh",
    "patch": "npm version patch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev:link": "bash scripts/dev-link.sh",
    "dev:unlink": "bash scripts/dev-unlink.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^6.7.0",
    "pdf-lib": "^1.17.1",
    "zod": "^4.3.6"
  }
}
